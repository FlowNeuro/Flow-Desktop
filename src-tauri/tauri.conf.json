{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Flow",
  "version": "0.1.0",
  "identifier": "io.github.aedev.flow.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "Flow",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 640,
        "decorations": false,
        "additionalBrowserArgs": "--autoplay-policy=no-user-gesture-required"
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: data: blob: https: http://127.0.0.1:*; media-src 'self' asset: http://127.0.0.1:*; connect-src 'self' ipc: http://127.0.0.1:*; font-src 'self'; object-src 'none'; base-uri 'none'; frame-src 'none';"
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["flow"]
      }
    },
    "updater": {
      "endpoints": [
        "https://github.com/A-EDev/flow-desktop/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEQ3NjQyOEVCREQxMjY5MjkKUldRcGFSTGQ2eWhrMThHMzB3Y29Tc3JsTFhpOGJqR1lGY0M0Z01DaVlzL01zNXhLTWUzUDdxcFIK",
      "windows": {
        "installMode": "passive"
      }
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "category": "Entertainment",
    "shortDescription": "The privacy-first desktop companion to Flow for Android.",
    "longDescription": "Flow Desktop is a privacy-first YouTube and YouTube Music companion to Flow for Android, with native playback and the fully local FlowNeuro recommendation engine.",
    "copyright": "Copyright © 2025-2026 A-EDev",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "sidecar/integrity.cjs"
    ],
    "macOS": {
      "minimumSystemVersion": "13.0",
      "signingIdentity": "-"
    },
    "windows": {
      "allowDowngrades": false,
      "webviewInstallMode": {
        "type": "downloadBootstrapper",
        "silent": true
      }
    },
    "linux": {
      "deb": {
        "depends": [
          "gstreamer1.0-plugins-base",
          "gstreamer1.0-plugins-good",
          "gstreamer1.0-plugins-bad",
          "gstreamer1.0-libav"
        ],
        "recommends": [
          "gstreamer1.0-plugins-ugly",
          "gstreamer1.0-vaapi"
        ]
      },
      "rpm": {
        "depends": [
          "gstreamer1-plugins-base",
          "gstreamer1-plugins-good",
          "gstreamer1-plugins-bad-free"
        ],
        "recommends": [
          "gstreamer1-plugins-bad-freeworld",
          "gstreamer1-libav"
        ]
      }
    }
  }
}
