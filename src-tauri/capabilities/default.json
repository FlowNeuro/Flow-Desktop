{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "main-capability",
  "description": "Main window permissions for Flow Desktop",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "os:allow-arch",
    "os:allow-family",
    "os:allow-locale",
    "os:allow-os-type",
    "os:allow-platform",
    "os:allow-version",
    "opener:default",
    "notification:default"
  ]
}
